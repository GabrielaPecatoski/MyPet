# ─────────────────────────────────────────────────────────────────────────────
# MyPet — Variáveis de ambiente para desenvolvimento local
# Copie este arquivo para .env em cada microserviço:
#   cp .env.example auth-service/.env
#   cp .env.example user-pet-service/.env
#   ... etc
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (PostgreSQL via Docker) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:root@localhost:5432/mypet

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=mypet_super_secret_change_in_production

# ── RabbitMQ (via Docker) ─────────────────────────────────────────────────────
RABBITMQ_URL=amqp://mypet:mypet123@localhost:5672

# ── Consul (via Docker) ───────────────────────────────────────────────────────
CONSUL_HOST=localhost
CONSUL_PORT=8500

# ── Porta do serviço (cada serviço usa uma porta diferente) ───────────────────
# auth-service:         PORT=3001
# user-pet-service:     PORT=3002
# establishment-service: PORT=3003
# marketplace-service:  PORT=3004
# booking-service:      PORT=3005
# notification-service: PORT=3006
# review-service:       PORT=3007
# api-gateway:          PORT=3000
